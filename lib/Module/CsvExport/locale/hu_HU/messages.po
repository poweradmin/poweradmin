msgstr "Nincsenek a zónában exportálható rekordok."

#: lib/Module/CsvExport/Controller/CsvExportController.php:56
msgid "You do not have permission to export this zone."
msgstr "Nincs jogosultsága a zóna exportálására."

#: lib/Module/CsvExport/Controller/CsvExportController.php:39
msgid "You need to be logged in to export zone data."
msgstr "A zóna adatok exportálásához be kell jelentkeznie."

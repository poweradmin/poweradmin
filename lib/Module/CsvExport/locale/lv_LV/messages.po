#: lib/Module/CsvExport/Controller/CsvExportController.php:45
msgid "Invalid zone ID."
msgstr "Nederīgs zonas ID."

#: lib/Module/CsvExport/Controller/CsvExportController.php:64
msgid "There is no zone with this ID."
msgstr "Nav zonas ar šo ID."

#: lib/Module/CsvExport/Controller/CsvExportController.php:72

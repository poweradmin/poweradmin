#: lib/Module/CsvExport/Controller/CsvExportController.php:45
msgid "Invalid zone ID."
msgstr "Virheellinen alueen tunnus."

#: lib/Module/CsvExport/Controller/CsvExportController.php:64
msgid "There is no zone with this ID."
msgstr "Tätä tunnusta vastaavaa aluetta ei ole."

#: lib/Module/CsvExport/Controller/CsvExportController.php:72
msgid "This zone does not have any records to export."
msgstr "Tässä alueessa ei ole tietueita vietäväksi."

#: lib/Module/CsvExport/Controller/CsvExportController.php:56
msgid "You do not have permission to export this zone."
msgstr "Sinulla ei ole oikeutta viedä tätä aluetta."

#: lib/Module/CsvExport/Controller/CsvExportController.php:39
msgid "You need to be logged in to export zone data."
msgstr "Alueen tietojen vientiä varten on oltava kirjautunut sisään."

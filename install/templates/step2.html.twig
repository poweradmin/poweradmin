{% extends 'base.html.twig' %}

{% block step_description %}{% trans %}System Requirements{% endtrans %}{% endblock %}

{% block content %}
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-secondary text-white">
            {% trans %}Step{% endtrans %} {{ current_step }}: {% trans %}System Requirements Check{% endtrans %}
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-lg-6">
                    <h6 class="text-muted small text-uppercase mb-2">{% trans %}PHP Version{% endtrans %}</h6>
                    {% if php_version_ok %}
                        <div class="check-row small">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>{{ php_version }}</strong>
                            <span class="text-muted ms-1">{% trans %}OK{% endtrans %}</span>
                        </div>
                    {% else %}
                        <div class="alert alert-danger py-1 mb-0 small">
                            <i class="bi bi-x-circle-fill"></i>
                            <strong>{{ php_version }}</strong> - {% trans %}Requires PHP 8.2.0+{% endtrans %}
                        </div>
                    {% endif %}
                </div>

                <div class="col-lg-6">
                    <h6 class="text-muted small text-uppercase mb-2">
                        {% trans %}Database Extensions{% endtrans %}
                        <span class="text-muted text-lowercase fw-normal">({% trans %}at least one required{% endtrans %})</span>
                    </h6>
                    <div class="row g-1">
                        {% for extension, status in database_extensions %}
                            <div class="col-md-4">
                                {% if status %}
                                    <div class="check-row small">
                                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                                        <strong>{{ extension }}</strong>
                                    </div>
                                {% else %}
                                    <div class="check-row small text-muted">
                                        <i class="bi bi-dash-circle me-2"></i>
                                        {{ extension }}
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <h6 class="text-muted small text-uppercase mb-2">{% trans %}Required PHP Extensions{% endtrans %}</h6>
            <div class="row g-1 mb-3">
                {% for extension, status in required_extensions %}
                    <div class="col-md-3 col-sm-6">
                        {% if status %}
                            <div class="check-row small">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <strong>{{ extension }}</strong>
                            </div>
                        {% else %}
                            <div class="alert alert-danger py-1 mb-1 small">
                                <i class="bi bi-x-circle-fill"></i>
                                <strong>{{ extension }}</strong>
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

            <hr class="my-3">

            <h6 class="text-muted small text-uppercase mb-2">{% trans %}Optional Extensions{% endtrans %}</h6>
            <div class="row g-1 mb-3">
                {% for extension, status in optional_extensions %}
                    <div class="col-md-3 col-sm-6">
                        {% if status %}
                            <div class="check-row small">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <strong>{{ extension }}</strong>
                            </div>
                        {% else %}
                            <div class="check-row small text-muted">
                                <i class="bi bi-dash-circle me-2"></i>
                                {{ extension }}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

            <hr class="my-3">

            <h6 class="text-muted small text-uppercase mb-2">{% trans %}Web Server{% endtrans %}</h6>
            <div class="row g-1 mb-3">
                <div class="col-md-6">
                    <div class="check-row small">
                        <i class="bi bi-info-circle text-secondary me-2"></i>
                        <strong>{% trans %}Server{% endtrans %}:</strong>
                        <span class="ms-1">{{ web_server_info.server_software }}</span>
                    </div>
                </div>
                <div class="col-md-6">
                    {% if web_server_info.is_apache %}
                        {% if web_server_info.can_detect_modules %}
                            {% if web_server_info.mod_rewrite_loaded %}
                                <div class="check-row small">
                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                    <strong>mod_rewrite:</strong>
                                    <span class="ms-1">{% trans %}Enabled{% endtrans %}</span>
                                </div>
                            {% else %}
                                <div class="alert alert-warning py-1 mb-0 small">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <strong>mod_rewrite:</strong> {% trans %}Not detected — required for URL routing{% endtrans %}
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="check-row small text-muted">
                                <i class="bi bi-info-circle me-2"></i>
                                <strong>mod_rewrite:</strong> {% trans %}Cannot detect (PHP-FPM) — ensure it is enabled{% endtrans %}
                            </div>
                        {% endif %}
                    {% elseif web_server_info.is_nginx %}
                        <div class="check-row small text-muted">
                            <i class="bi bi-info-circle me-2"></i>
                            {% trans %}Ensure URL rewriting is configured (see nginx.conf.example){% endtrans %}
                        </div>
                    {% else %}
                        <div class="check-row small text-muted">
                            <i class="bi bi-info-circle me-2"></i>
                            {% trans %}Ensure URL rewriting is configured for your web server{% endtrans %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <form method="post" class="mt-3">
                <input type="hidden" name="install_token" value="{{ install_token }}">
                <input type="hidden" name="language" value="{{ language }}">
                <input type="hidden" name="step" value="{{ next_step }}">

                {% if requirements_ok %}
                    <div class="alert alert-success py-2 mb-3 small">
                        <i class="bi bi-check-circle-fill"></i>
                        <strong>{% trans %}All required components are available.{% endtrans %}</strong>
                        {% trans %}You can continue with the installation.{% endtrans %}
                    </div>
                    <div class="text-center">
                        <input type="submit" name="submit" class="btn btn-sm btn-primary"
                               value="{% trans %}Continue to step{% endtrans %} {{ next_step }}">
                    </div>
                {% else %}
                    <div class="alert alert-danger py-2 mb-0 small">
                        <i class="bi bi-x-circle-fill"></i>
                        <strong>{% trans %}Some required components are missing.{% endtrans %}</strong>
                        {% trans %}Please install the missing components before continuing.{% endtrans %}
                    </div>
                {% endif %}
            </form>
        </div>
    </div>

    <style>
        .check-row {
            display: flex;
            align-items: center;
            padding: 0.25rem 0.25rem;
            line-height: 1.4;
        }
    </style>
{% endblock %}
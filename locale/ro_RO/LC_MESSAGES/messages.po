msgstr "Câmpul key tag RRSIG trebuie numeric."

#: lib/Domain/Service/DnsValidation/RRSIGRecordValidator.php:307
msgid "RRSIG key tag must be a valid value between 0 and 65535."
msgstr "Tag cheie RRSIG 0-65535."

#: lib/Domain/Service/DnsValidation/RRSIGRecordValidator.php:312

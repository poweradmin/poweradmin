#: lib/AppInitializer.php:82
#, php-format
msgid ""
"No configuration file found at %s. Please use the <a href=\"install/"
"\">installer</a> to create one, or create the configuration file manually."
msgstr ""
"No configuration file found at %s. Please use the <a href=\"install/"
"\">installer</a> to create one, or create the configuration file manually."

#: lib/Application/Controller/AddRecordController.php:184
msgid ""
"This record was not valid and could not be added. It may already exist or "
"contain invalid data."
msgstr ""
"Ovaj zapis nije bio valjan i nije se mogao dodati. Možda postoji ili je nevažeći."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:59
msgid ""
"TLSA records require DNSSEC to be enabled for this zone. TLSA records "
"without DNSSEC will not provide security benefits and may be ignored by "
"clients."
msgstr ""
"TLSA records require DNSSEC to be enabled for this zone. TLSA records "
"without DNSSEC will not provide security benefits and may be ignored by "
"clients."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:72
msgid ""
"TCP/UDP port number (443 for HTTPS, 25 for SMTP, 853 for DNS-over-TLS, etc.)"
msgstr "TCP/UDP broj porta (443 za HTTPS, 25 za SMTP, 853 za DNS-over-TLS)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:93
msgid ""
"Hostname for the service (leave empty for zone apex @). Record will be "
"created at _port._protocol.hostname"
msgstr ""
"Ime poslužitelja za uslugu (prazno za apex @). Zapis: _port._protocol.hostname"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:112
msgid ""
"How the certificate should be validated. Type 3 is most common for self-"
"signed or custom CAs."
msgstr "Kako treba validirati certifikat. Tip 3 je uobičajen za self-signed."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:129
msgid ""
"What part of the certificate to match. Type 1 (public key) survives "
"certificate renewal."
msgstr ""
"Koji dio certifikata treba podudarati. Tip 1 (javni ključ) preživljava obnovu."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:147
msgid ""
"How to encode the certificate data. SHA-256 (type 1) provides good balance "
"of security and length."
msgstr "Kako kodirati podatke certifikata. SHA-256 (tip 1) daje dobar balans."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:161
msgid ""
"Hexadecimal hash or full certificate data (depending on matching type). For "
"SHA-256: use \"openssl x509 -in cert.pem -pubkey -noout | openssl pkey "
"-pubin -outform DER | openssl dgst -sha256\""
msgstr ""
"Hexadecimal hash or full certificate data (depending on matching type). For "
"SHA-256: use \"openssl x509 -in cert.pem -pubkey -noout | openssl pkey "
"-pubin -outform DER | openssl dgst -sha256\""

#: lib/Module/DnsWizard/Service/TLSAWizard.php:259
#, php-format
msgid ""
"SHA-256 hash should be 64 hexadecimal characters, got %d. Verify the hash is "
"correct."
msgstr "SHA-256 hash treba biti 64 heksadecimalna znaka, dobiveno %d."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:263
#, php-format
msgid ""
"SHA-512 hash should be 128 hexadecimal characters, got %d. Verify the hash "
"is correct."
msgstr "SHA-512 hash treba biti 128 heksadecimalnih znakova, dobiveno %d."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:267
msgid ""
"Full certificate data seems too short. Ensure you provided the complete "
"certificate."
msgstr "Potpuni podaci certifikata izgledaju prekratko. Osigurajte cjelovitost."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:278
msgid ""
"CRITICAL: TLSA records require DNSSEC to be enabled on this zone. Without "
"DNSSEC, TLSA records provide NO security benefit."
msgstr "KRITIČNO: TLSA zapisi zahtijevaju DNSSEC. Bez DNSSEC nema sigurnosti."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:72
msgid "Start with \"none\" to collect data before enforcing a stricter policy."
msgstr "Počnite s \"none\" za prikupljanje podataka prije strogog pravila."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:96
msgid ""
"Percentage of messages to which the policy should apply (100 = all "
"messages). Use lower values during policy rollout."
msgstr "Postotak poruka na koje se pravilo primjenjuje (100 = sve)."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:117
msgid ""
"Email address to receive detailed failure reports (optional, can be high "
"volume)"
msgstr "Adresa e-pošte za detaljna izvješća (opcionalno, veliki obim)"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:130
msgid ""
"When to generate forensic reports (only applies if forensic email is set)"
msgstr "Kada generirati forenzička izvješća (ako je e-pošta postavljena)"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:277
#, php-format
msgid ""
"Policy will only apply to %d%% of messages. Use 100%% once testing is "
"complete."
msgstr "Pravilo se primjenjuje na %d%% poruka. Koristite 100%% nakon testiranja."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:292
msgid ""
"No reporting email addresses configured. You will not receive DMARC reports."
msgstr "Nema konfiguriranih adresa e-pošte. Nećete primati DMARC izvješća."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:305
msgid ""
"Using \"p=none\" provides monitoring only. Consider stricter policy "
"(quarantine/reject) once you've reviewed reports."
msgstr ""
"\"p=none\" pruža samo nadzor. Razmotrite stroža pravila (quarantine/reject)."

#: lib/Module/DnsWizard/Service/SPFWizard.php:112
msgid ""
"Domains whose SPF records should be included (one per line). Common: "
"_spf.google.com, spf.protection.outlook.com"
msgstr ""
"Domene čije SPF zapise treba uključiti (jedan po redu). Česte: _spf.google.com."

#: lib/Module/DnsWizard/Service/SPFWizard.php:152
msgid ""
"Policy for emails not matching any mechanism. Start with ~all (softfail) for "
"testing."
msgstr ""
"Pravilo za e-poštu koja ne odgovara. Započnite s ~all (softfail) za testiranje."

#: lib/Module/DnsWizard/Service/SPFWizard.php:289
#, php-format
msgid ""
"SPF record exceeds the DNS lookup limit (%d/10). This will cause SPF "
"validation to fail. Remove some include/a/mx mechanisms or use ip4/ip6 "
"instead."
msgstr ""
"SPF record exceeds the DNS lookup limit (%d/10). This will cause SPF "
"validation to fail. Remove some include/a/mx mechanisms or use ip4/ip6 "
"instead."

#: lib/Module/DnsWizard/Service/SPFWizard.php:294
#, php-format
msgid ""
"SPF record has %d DNS lookups (limit is 10). Consider using ip4/ip6 instead "
"of include mechanisms, or consolidate includes to stay under the limit."
msgstr ""
"SPF record has %d DNS lookups (limit is 10). Consider using ip4/ip6 instead "
"of include mechanisms, or consolidate includes to stay under the limit."

#: lib/Module/DnsWizard/Service/SPFWizard.php:343
msgid ""
"No mechanisms selected. This SPF record will only contain the default action."
msgstr "Nema odabranih mehanizama. SPF zapis će sadržavati samo zadanu akciju."

#: lib/Module/DnsWizard/Service/SPFWizard.php:348
msgid ""
"Using \"+all\" allows anyone to send email as your domain. This is strongly "
"discouraged."
msgstr "\"+all\" dopušta svima slanje s vaše domene. Strogo se ne preporučuje."

#: lib/Module/DnsWizard/Service/CAAWizard.php:83
msgid ""
"Select the certificate authority authorized to issue certificates for this "
"domain"
msgstr "Odaberite certifikacijsko tijelo ovlašteno za izdavanje certifikata"

#: lib/Module/DnsWizard/Service/CAAWizard.php:92
msgid ""
"Enter the CA domain name manually (only shown when \"Custom\" is selected)"
msgstr "Unesite CA domenu ručno (vidljivo samo kad je \"Prilagođeno\")"

#: lib/Module/DnsWizard/Service/CAAWizard.php:138
msgid ""
"Non-critical (0) provides better compatibility. Critical (128) enforces "
"strict CAA processing."
msgstr ""
"Nekritično (0) pruža bolju kompatibilnost. Kritično (128) strogo CAA procesiranje."

#: lib/Module/DnsWizard/Service/CAAWizard.php:213
msgid "Custom CA domain is required when \"Custom\" is selected"
msgstr "Prilagođena CA domena je obavezna kad je odabrano \"Prilagođeno\""

#: lib/Module/DnsWizard/Service/CAAWizard.php:221
msgid ""
"Using \";\" allows ALL certificate authorities to issue certificates. This "
"defeats the purpose of CAA records."
msgstr "\";\" dopušta SVIM CA da izdaju certifikate, što poništava svrhu CAA."

#: lib/Module/DnsWizard/Service/CAAWizard.php:240
msgid ""
"Critical flag (128) is set. Systems that do not understand CAA records will "
"reject operations. Use 0 unless you have a specific requirement."
msgstr ""
"Critical flag (128) is set. Systems that do not understand CAA records will "
"reject operations. Use 0 unless you have a specific requirement."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:61
msgid ""
"DKIM proves emails are from your domain using cryptographic signatures. "
"Generate the DKIM key pair on your MAIL SERVER (Postfix, Exim, etc.). Only "
"the PUBLIC KEY goes in this DNS record. Keep the PRIVATE KEY secure on your "
"mail server (never share it)."
msgstr ""
"DKIM proves emails are from your domain using cryptographic signatures. "
"Generate the DKIM key pair on your MAIL SERVER (Postfix, Exim, etc.). Only "
"the PUBLIC KEY goes in this DNS record. Keep the PRIVATE KEY secure on your "
"mail server (never share it)."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:77
msgid ""
"Selector to identify the DKIM key (commonly \"default\", timestamp like "
"\"202501\", or service name like \"google\"). Only alphanumeric characters, "
"hyphens, and underscores allowed."
msgstr ""
"Selector to identify the DKIM key (commonly \"default\", timestamp like "
"\"202501\", or service name like \"google\"). Only alphanumeric characters, "
"hyphens, and underscores allowed."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:86
msgid ""
"Paste the base64-encoded public key from your mail server. Spaces and "
"newlines will be automatically removed."
msgstr ""
"Zalijepite base64 javni ključ iz svog poslužitelja. Razmaci će biti uklonjeni."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:112
msgid ""
"Enable testing mode (t=y). DKIM signatures will be present but not enforced. "
"Use during initial deployment."
msgstr ""
"Omogući način testiranja (t=y). DKIM potpisi postoje ali se ne primjenjuju."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:119
msgid ""
"Enable strict subdomain mode (t=s). Rejects unsigned mail from subdomains."
msgstr "Omogući strogi način (t=s). Odbija nepotpisanu poštu s poddomena."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:200
msgid ""
"Selector can only contain alphanumeric characters, hyphens, and underscores"
msgstr "Selektor smije sadržavati samo alfanumeričke znakove, crtice i podvlake"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:216
msgid ""
"Public key seems unusually short. Ensure you copied the complete key from "
"your mail server."
msgstr "Javni ključ izgleda prekratak. Osigurajte cjelovitost ključa."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:221
msgid ""
"You pasted a PRIVATE KEY. Only the PUBLIC KEY should be in DNS. Never share "
"your private key!"
msgstr "Zalijepili ste PRIVATNI ključ. U DNS ide samo JAVNI ključ!"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:225
msgid ""
"Public key appears to contain PEM headers (BEGIN/END). Only the base64 "
"content between headers is needed."
msgstr ""
"Javni ključ izgleda da sadrži PEM zaglavlja. Potreban je samo base64 sadržaj."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:239
msgid ""
"Testing mode is enabled (t=y). DKIM signatures will not be enforced. Disable "
"this once testing is complete."
msgstr "Način testiranja je omogućen (t=y). DKIM potpisi se ne primjenjuju."

#: lib/Module/DnsWizard/Service/SRVWizard.php:100
msgid "Select a common service or choose \"Custom\" to enter manually"
msgstr "Odaberite uobičajenu uslugu ili \"Prilagođeno\" za ručni unos"

#: lib/Module/DnsWizard/Service/SRVWizard.php:131
msgid ""
"Domain name (leave empty for zone apex @). Full record name will be: "
"_service._protocol.domain"
msgstr ""
"Naziv domene (prazno za vrh zone @). Puni naziv: _service._protocol.domain"

#: lib/Module/DnsWizard/Service/SRVWizard.php:144
msgid ""
"Hostname of the server providing this service (must be a hostname with an A/"
"AAAA record, not an IP address)"
msgstr ""
"Ime poslužitelja koji pruža uslugu (mora biti ime s A/AAAA zapisom, ne IP)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:154
msgid ""
"Port number where the service is listening (automatically filled for common "
"services)"
msgstr ""
"Broj porta na kojem usluga sluša (automatski popunjeno za uobičajene usluge)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:169
msgid ""
"Lower values have higher priority (10 is a good default). Clients try "
"servers in priority order."
msgstr "Niže vrijednosti imaju veći prioritet (10 je dobra zadana)."

#: lib/Module/DnsWizard/Service/SRVWizard.php:179
msgid ""
"For load balancing among servers with same priority. Higher weight = more "
"traffic. 0 = no load balancing."
msgstr ""
"Za uravnoteženje opterećenja između poslužitelja iste prioriteta. Veća težina = više prometa."

#: lib/Module/DnsWizard/Service/SRVWizard.php:282
msgid ""
"Target must be a hostname, not an IP address. Create an A or AAAA record for "
"the hostname first."
msgstr "Cilj mora biti ime poslužitelja, ne IP. Prvo stvorite A ili AAAA zapis."

#: lib/Module/DnsWizard/Service/SRVWizard.php:299
msgid ""
"Priority 0 is valid but unusual. Most services use priority 10 or higher."
msgstr "Prioritet 0 je valjan ali neobičan. Većina koristi 10 ili više."

#: lib/BaseController.php:592
msgid ""
"The <a href=\"install/\">install/</a> directory exists, you must remove it "
"first before proceeding."
msgstr ""
"<a href=\"install/\">install/</a> direktorij postoji, uklonite ga prije nastavka."

#: lib/BaseController.php:649
msgid ""
"Default session encryption key is used, please set it in your configuration "
"file."
msgstr "Koristi se zadani ključ sesije, postavite ga u konfiguraciji."

#: lib/Application/Controller/DeleteRecordsController.php:202
msgid ""
"The record has been deleted successfully. Any corresponding PTR records were "
"also removed."
msgstr "Zapis je uspješno obrisan. Svi odgovarajući PTR zapisi su uklonjeni."

#: lib/Application/Controller/DeleteRecordsController.php:204
#, php-format
msgid ""
"%d records have been deleted successfully. Any corresponding PTR records "
"were also removed."
msgstr "%d zapisa uspješno obrisano. Svi odgovarajući PTR zapisi su uklonjeni."

#: lib/Application/Controller/DeleteRecordsController.php:276
msgid ""
"No valid records selected for deletion or you lack permission to delete them."
msgstr "Nema odabranih valjanih zapisa ili nemate dozvolu za brisanje."

#: lib/Application/Controller/DeleteRecordController.php:215
msgid ""
"The record and its corresponding PTR and A/AAAA records were deleted but the "
"comment was preserved because similar records exist."
msgstr ""
"The record and its corresponding PTR and A/AAAA records were deleted but the "
"comment was preserved because similar records exist."

#: lib/Application/Controller/DeleteRecordController.php:217
msgid ""
"The record and its corresponding PTR record were deleted but the comment was "
"preserved because similar records exist."
msgstr ""
"Zapis i odgovarajući PTR su obrisani ali komentar sačuvan zbog sličnih zapisa."

#: lib/Application/Controller/DeleteRecordController.php:219
msgid ""
"The record and its corresponding A/AAAA record were deleted but the comment "
"was preserved because similar records exist."
msgstr ""
"Zapis i odgovarajući A/AAAA su obrisani ali komentar sačuvan zbog sličnih."

#: lib/Application/Controller/DeleteRecordController.php:221
msgid ""
"The record was deleted but the comment was preserved because similar records "
"exist."
msgstr "Zapis je obrisan ali komentar je sačuvan jer postoje slični zapisi."

#: lib/Application/Controller/DeleteRecordController.php:225
msgid ""
"The record and its corresponding PTR and A/AAAA records have been deleted "
"successfully."
msgstr "Zapis i odgovarajući PTR i A/AAAA zapisi su uspješno obrisani."

#: lib/Application/Controller/DeleteRecordController.php:227
msgid ""
"The record and its corresponding PTR record have been deleted successfully."
msgstr "Zapis i odgovarajući PTR zapis su uspješno obrisani."

#: lib/Application/Controller/DeleteRecordController.php:229
msgid ""
"The record and its corresponding A/AAAA record have been deleted "
"successfully."
msgstr "Zapis i odgovarajući A/AAAA zapis su uspješno obrisani."

#: lib/Application/Controller/DeleteRecordController.php:231
msgid ""
"The record has been deleted successfully. No matching PTR record was found."
msgstr "Zapis uspješno obrisan. Nije pronađen odgovarajući PTR zapis."

#: lib/Application/Controller/DeleteRecordController.php:233
msgid ""
"The record has been deleted successfully. No matching A/AAAA record was "
"found."
msgstr "Zapis uspješno obrisan. Nije pronađen odgovarajući A/AAAA zapis."


#: lib/Application/Controller/ChangePasswordController.php:94
msgid ""
"Users authenticated via Single Sign-On cannot change their password here. "
"Please contact your administrator or change your password through your "
"identity provider."
msgstr ""
"Users authenticated via Single Sign-On cannot change their password here. "
"Please contact your administrator or change your password through your "
"identity provider."

#: lib/Application/Controller/ChangePasswordController.php:95

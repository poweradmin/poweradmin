#: lib/Application/Controller/MfaSetupController.php:187
msgid ""
"Email address is not available. Please update your email address in your "
"profile."
msgstr "Adresa e-pošte nije dostupna. Ažurirajte je u profilu."

#: lib/Application/Controller/MfaSetupController.php:194
msgid ""
"Email verification method is not available because mail service is not "
"enabled on this system."
msgstr "Metoda provjere e-pošte nije dostupna jer mail usluga nije omogućena."

#: lib/Application/Controller/MfaSetupController.php:243
msgid ""
"Failed to send verification code. Please try again later or use app-based "
"authentication."
msgstr ""
"Neuspjelo slanje koda za potvrdu. Pokušajte kasnije ili koristite aplikaciju."

#: lib/Application/Controller/MfaSetupController.php:300
#: templates/default/mfa_setup.html:38 templates/modern/mfa_setup.html:38
msgid ""
"MFA is required by your organization's security policy and cannot be "
"disabled."
msgstr ""
"MFA je obavezan prema sigurnosnom pravilu organizacije i ne može se onemogućiti."

#: lib/Application/Controller/MfaSetupController.php:352
msgid "Recovery codes have been regenerated. Please save them in a safe place."
msgstr "Kodovi za oporavak su ponovno generirani. Spremite ih na sigurno."

#: lib/Application/Controller/EditZoneMetadataController.php:381
#, php-format
msgid ""
"Metadata kind %s accepts only a single value. Add only one row for this kind."
msgstr ""
"Vrsta metapodataka %s prihvaća samo jednu vrijednost. Dodajte samo jedan red."

#: lib/Application/Controller/EditZoneMetadataController.php:469
#: templates/modern/edit_zone_metadata.html:153
msgid ""
"Custom metadata kind stored directly in the PowerDNS domainmetadata table."
msgstr ""
"Prilagođena vrsta metapodataka pohranjena u PowerDNS domainmetadata tablici."

#: lib/Domain/Model/ZoneTemplate.php:189 lib/Domain/Model/ZoneTemplate.php:877
msgid "Zone template with this name already exists, please choose another one."
msgstr "Predložak zone s ovim imenom već postoji, odaberite drugo."

#: lib/Application/Controller/UnlinkZonesTemplController.php:99
#, php-format
msgid "%d zone has been unlinked from template successfully."
msgid_plural "%d zones have been unlinked from template successfully."
msgstr[0] "%d zone has been unlinked from template successfully."
msgstr[1] "%d zones have been unlinked from template successfully."
msgstr[2] "%d zones have been unlinked from template successfully."

#: lib/Application/Controller/UnlinkZonesTemplController.php:109
#, php-format
msgid "%d zone could not be unlinked."
msgid_plural "%d zones could not be unlinked."
msgstr[0] "%d zone could not be unlinked."
msgstr[1] "%d zones could not be unlinked."
msgstr[2] "%d zones could not be unlinked."

#: lib/Application/Controller/EditController.php:344
msgid ""
"Zone signing requested successfully, but verification failed. Check DNSSEC "
"keys."
msgstr "Zahtjev za potpisivanje zone uspješan, ali provjera nije uspjela."

#: lib/Application/Controller/EditController.php:348
msgid ""
"Failed to sign zone. Zone validation passed, but PowerDNS API returned an "
"error. Check PowerDNS logs for details."
msgstr ""
"Neuspjelo potpisivanje zone. Validacija prošla, ali PowerDNS API je vratio grešku."

#: lib/Application/Controller/EditController.php:741
msgid ""
"Zone saved successfully. No record changes were made, but SOA serial was "
"incremented."
msgstr ""
"Zona uspješno spremljena. Nema promjena zapisa, ali SOA serijski broj je povećan."

#: lib/Application/Controller/MfaVerifyController.php:297
msgid ""
"Email verification is not available because mail service is disabled. Please "
"use a recovery code."
msgstr ""
"Provjera e-pošte nije dostupna - mail služba je onemogućena. Koristite kod za oporavak."

#: lib/Application/Controller/MfaVerifyController.php:318
msgid ""
"Could not send verification code to your email. Please use a recovery code "
"instead."
msgstr "Nije moguće poslati kod na e-poštu. Koristite kod za oporavak."

#: lib/Application/Controller/AddRecordController.php:493
msgid ""
"Some records could not be added. They may already exist or contain invalid "
"data."
msgstr "Neki zapisi nisu mogli biti dodani. Možda već postoje ili su nevažeći."

#: lib/Application/Controller/AddZoneMasterController.php:173
msgid ""
"Zone was created successfully, but DNSSEC signing was skipped due to "
"validation errors:"
msgstr ""
"Zona je uspješno stvorena, ali DNSSEC potpisivanje preskočeno zbog validacije:"

#: lib/Application/Controller/AddZoneMasterController.php:185
msgid ""
"Zone was created, but securing it with DNSSEC failed. Zone validation "
"passed, but PowerDNS API returned an error. Check PowerDNS logs for details."
msgstr ""
"Zone was created, but securing it with DNSSEC failed. Zone validation "
"passed, but PowerDNS API returned an error. Check PowerDNS logs for details."

#: lib/Application/Controller/AddZoneMasterController.php:194
msgid ""
"Zone was created and signing was requested, but verification failed. Check "
"DNSSEC keys."
msgstr "Zona je stvorena i potpisivanje zatraženo, ali provjera nije uspjela."

#: lib/Application/Controller/ManageGroupZonesController.php:149
#, php-format
msgid "%d zone added to group."
msgid_plural "%d zones added to group."
msgstr[0] "%d zone added to group."

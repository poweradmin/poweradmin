msgstr "Preverjanje celotne poti do datoteke zbirke podatkov je pravilno in dostopno"

#: install/helpers/InstallStepHandler.php:226
msgid "Verify database credentials are correct"
msgstr "Preverjanje poverilnic zbirke podatkov je pravilno"

#: install/helpers/InstallStepHandler.php:227
msgid "Check that the database user has sufficient privileges"
msgstr "Preverite, ali ima uporabnik zbirke podatkov dovolj privilegijev"

#: install/helpers/InstallStepHandler.php:228
msgid "Ensure the database server is running and accessible"
msgstr "Zagotovitev delovanja in dostopnosti strežnika zbirke podatkov"

#: install/helpers/InstallStepHandler.php:233
msgid "Database Error"
msgstr "Napaka zbirke podatkov"

#: install/helpers/DatabaseHelper.php:175
#, php-format
msgid ""
"The SQLite database file %s does not exist. Please create the database file "
"before proceeding."
msgstr "Datoteka zbirke podatkov SQLite %s ne obstaja. Pred nadaljevanjem ustvarite datoteko z bazo podatkov."

#: install/helpers/DatabaseHelper.php:183
#, php-format
msgid ""
"The SQLite database file %s is not readable. Please check file permissions."
msgstr "Datoteka zbirke podatkov SQLite %s ni berljiva. Prosim preverite dovoljenja za datoteko."

#: install/helpers/DatabaseHelper.php:191
#, php-format
msgid ""
"The SQLite database file %s is not writable. Please check file permissions."
msgstr "Datoteka zbirke podatkov SQLite %s ni zapisljiva. Prosim preverite dovoljenja za datoteko."

#: install/helpers/DatabaseHelper.php:203
#, php-format
msgid "Could not access the SQLite database file %s: %s"
msgstr "Ni moč dostopati do datoteke zbirke podatkov SQLite %s: %s"

#: install/helpers/Validators/ConfiguringDatabaseValidator.php:72
msgid "PowerDNS API URL is required when using API backend."
msgstr "Pri uporabi hrbtenjače API je potreben URL PowerDNS API."

#: install/helpers/Validators/ConfiguringDatabaseValidator.php:75
msgid "PowerDNS API key is required when using API backend."
msgstr "Pri uporabi hrbtenjače API je potreben ključ PowerDNS API."

#: install/helpers/Validators/CreateConfigurationFileValidator.php:54
msgid ""
"No configuration file found. Please create the config/settings.php file "
"before proceeding."
msgstr "Ni moč najti nastavitvene datoteke. Pred nadaljevanjem ustvarite datoteko config/setts.php."

#: install/helpers/Validators/PdnsDatabaseValidationTrait.php:52
msgid ""
"Separate PowerDNS databases are only supported with MySQL. For PostgreSQL "
"and SQLite, please use the same database."
msgstr "Ločene PowerDNS baze podatkov so podprte samo z MySQL. Za PostgreSQL in SQLite uporabite isto bazo podatkov."

#: install/helpers/Validators/PdnsDatabaseValidationTrait.php:80
#, php-format
msgid ""
"Missing PowerDNS tables in database \"%s\": %s. Please ensure PowerDNS is "
"properly installed in this database."
msgstr "Manjkajoče tabele PowerDNS v bazi podatkov \"%s\": %s. Poskrbite, da bo PowerDNS pravilno nameščen v tej bazi podatkov."

#: install/helpers/Validators/PdnsDatabaseValidationTrait.php:87
#, php-format
msgid "Cannot connect to PowerDNS database \"%s\": %s"
msgstr "Ni se moč povezati s podatkovno bazo PowerDNS \"%s\": %s"

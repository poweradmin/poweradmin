msgid "Strict Subdomain Mode"
msgstr "Modo Rigoroso de Subdomínio"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:119
msgid ""
"Enable strict subdomain mode (t=s). Rejects unsigned mail from subdomains."
msgstr ""
"Ativar modo rigoroso de subdomínio (t=s). Rejeita emails não assinados de "
"subdomínios."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:198
msgid "Selector is required"
msgstr "Seletor é obrigatório"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:200
msgid ""
"Selector can only contain alphanumeric characters, hyphens, and underscores"
msgstr ""
"Seletor pode apenas conter caracteres alfanuméricos, hífens e underscores"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:205
msgid "Public key is required"
msgstr "Chave pública é obrigatória"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:211
msgid "Public key must be valid base64-encoded data"
msgstr "Chave pública deve ser dados válidos codificados em base64"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:216
msgid ""
"Public key seems unusually short. Ensure you copied the complete key from "
"your mail server."
msgstr ""
"Chave pública parece invulgarmente curta. Certifique-se de que copiou a "
"chave completa do seu servidor de email."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:221
msgid ""
"You pasted a PRIVATE KEY. Only the PUBLIC KEY should be in DNS. Never share "
"your private key!"
msgstr ""
"Colou uma CHAVE PRIVADA. Apenas a CHAVE PÚBLICA deve estar no DNS. Nunca "
"partilhe a sua chave privada!"


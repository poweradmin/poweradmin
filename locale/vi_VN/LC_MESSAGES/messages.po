msgid "Flags"
msgstr "Cờ"

#: lib/Module/DnsWizard/Service/CAAWizard.php:135
msgid "Non-critical"
msgstr "Không quan trọng"

#: lib/Module/DnsWizard/Service/CAAWizard.php:135

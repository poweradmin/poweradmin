msgid "Matching Type"
msgstr "نوع المطابقة"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:143
msgid "0 - Exact Match"
msgstr "0 - تطابق دقيق"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:143

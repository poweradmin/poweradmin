msgstr "gateway-type 为 1 的 IPSECKEY 需要 IPv4 地址"

#: lib/Domain/Service/Dns.php:3666
msgid "IPSECKEY gateway must be a valid IPv4 address"
msgstr "IPSECKEY gateway 必须是有效的 IPv4 地址"


#: lib/AppInitializer.php:82
#, php-format
msgid ""
"No configuration file found at %s. Please use the <a href=\"install/"
"\">installer</a> to create one, or create the configuration file manually."
msgstr ""
"Файл конфигурации не найден. Пожалуйста, используйте <a href=\"install/"
"\">установщик</a> для его создания или создайте файл %s вручную."

#: lib/Module/DnsWizard/Controller/DnsWizardSelectController.php:57
msgid "DNS wizards are not enabled."
msgstr "DNS-мастера не включены."

#: lib/Application/Controller/DnssecToggleKeyController.php:48
msgid "Invalid zone ID."
msgstr "Недопустимый ID зоны."

#: lib/Application/Controller/ZoneOwnershipController.php:95
msgid "Zone not found."
msgstr "Зона не найдена."

#: lib/Module/DnsWizard/Controller/DnsWizardSelectController.php:80
msgid "You do not have permission to add records to this zone."
msgstr "У вас нет прав на добавление записей в эту зону."

#: lib/Module/DnsWizard/Controller/DnsWizardFormController.php:118
msgid "Invalid wizard type."
msgstr "Неверный тип мастера."

#: lib/Module/DnsWizard/Controller/DnsWizardFormController.php:204
msgid "Validation failed:"
msgstr "Проверка не удалась:"

#: lib/Module/DnsWizard/Controller/DnsWizardFormController.php:228
msgid "Failed to generate record:"
msgstr "Не удалось создать запись:"

#: lib/Application/Controller/AddRecordController.php:184
msgid ""
"This record was not valid and could not be added. It may already exist or "
"contain invalid data."
msgstr ""
"Эта запись недействительна и не может быть добавлена. Возможно, она уже "
"существует или содержит недопустимые данные."

#: lib/Application/Controller/AddRecordController.php:260
msgid "The record was successfully added."
msgstr "Запись была успешно добавлена."

#: lib/Module/DnsWizard/Controller/Api/DnsWizardApiController.php:414
msgid "Record created successfully"
msgstr "Запись успешно создана"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:45
msgid "TLSA Record"
msgstr "Запись TLSA"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:46
msgid "TLS certificate/key authentication (DANE)"
msgstr "Аутентификация сертификата/ключа TLS (DANE)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:57
msgid "DNSSEC Requirement"
msgstr "Требование DNSSEC"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:59
msgid ""
"TLSA records require DNSSEC to be enabled for this zone. TLSA records "
"without DNSSEC will not provide security benefits and may be ignored by "
"clients."
msgstr ""
"Записи TLSA требуют включения DNSSEC для этой зоны. Записи TLSA без DNSSEC "
"не обеспечат преимуществ безопасности и могут быть проигнорированы клиентами."

#: lib/Module/DnsWizard/Service/SRVWizard.php:91
msgid "Service Configuration"
msgstr "Конфигурация службы"

#: lib/Module/DnsWizard/Service/SRVWizard.php:148
msgid "Port Number"
msgstr "Номер порта"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:72
msgid ""
"TCP/UDP port number (443 for HTTPS, 25 for SMTP, 853 for DNS-over-TLS, etc.)"
msgstr ""
"Номер порта TCP/UDP (443 для HTTPS, 25 для SMTP, 853 для DNS-over-TLS и т.д.)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:113
msgid "Protocol"
msgstr "Протокол"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:81
msgid "Transmission Control Protocol - most common for HTTPS/TLS"
msgstr "Transmission Control Protocol - наиболее распространен для HTTPS/TLS"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:82
msgid "User Datagram Protocol - for DTLS connections"
msgstr "User Datagram Protocol - для соединений DTLS"

#: lib/Module/DnsWizard/Service/SRVWizard.php:121
msgid "Stream Control Transmission Protocol"
msgstr "Stream Control Transmission Protocol"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:85
msgid "Transport protocol for the TLS connection"
msgstr "Транспортный протокол для соединения TLS"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:89
msgid "Hostname"
msgstr "Имя хоста"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:93
msgid ""
"Hostname for the service (leave empty for zone apex @). Record will be "
"created at _port._protocol.hostname"
msgstr ""
"Имя хоста для службы (оставьте пустым для вершины зоны @). Запись будет "
"создана в _порт._протокол.имя_хоста"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:98
msgid "Certificate Usage"
msgstr "Использование сертификата"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:102
msgid "Usage"
msgstr "Использование"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:107
msgid "0 - CA Constraint"
msgstr "0 - Ограничение CA"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:107
msgid "Certificate must chain to specified CA (PKIX-TA)"
msgstr "Сертификат должен связываться с указанным CA (PKIX-TA)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:108
msgid "1 - Service Certificate"
msgstr "1 - Сертификат службы"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:108
msgid "Certificate must match exactly (PKIX-EE)"
msgstr "Сертификат должен точно совпадать (PKIX-EE)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:109
msgid "2 - Trust Anchor Assertion"
msgstr "2 - Утверждение якоря доверия"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:109
msgid "Certificate must chain to specified anchor (DANE-TA)"
msgstr "Сертификат должен связываться с указанным якорем (DANE-TA)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:110
msgid "3 - Domain-Issued Certificate"
msgstr "3 - Сертификат, выданный доменом"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:110
msgid "Certificate must match exactly, bypassing PKI (DANE-EE)"
msgstr "Сертификат должен точно совпадать, минуя PKI (DANE-EE)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:112
msgid ""
"How the certificate should be validated. Type 3 is most common for self-"
"signed or custom CAs."
msgstr ""
"Как должен проверяться сертификат. Тип 3 наиболее распространен для "
"самоподписанных или пользовательских CA."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:72
msgid "Selector"
msgstr "Селектор"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:126
msgid "0 - Full Certificate"
msgstr "0 - Полный сертификат"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:126
msgid "Use the entire certificate"
msgstr "Использовать весь сертификат"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:127
msgid "1 - Public Key"
msgstr "1 - Открытый ключ"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:127
msgid "Use only the Subject Public Key Info (SPKI)"
msgstr "Использовать только Subject Public Key Info (SPKI)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:129
msgid ""
"What part of the certificate to match. Type 1 (public key) survives "
"certificate renewal."
msgstr ""
"Какую часть сертификата сопоставлять. Тип 1 (открытый ключ) сохраняется при "
"обновлении сертификата."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:138
msgid "Matching Type"
msgstr "Тип сопоставления"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:143
msgid "0 - Exact Match"
msgstr "0 - Точное совпадение"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:143
msgid "Full certificate/key data (very long record)"
msgstr "Полные данные сертификата/ключа (очень длинная запись)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:144
msgid "1 - SHA-256 Hash"
msgstr "1 - Хеш SHA-256"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:144
msgid "SHA-256 hash of certificate/key"
msgstr "Хеш SHA-256 сертификата/ключа"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:145
msgid "2 - SHA-512 Hash"
msgstr "2 - Хеш SHA-512"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:145
msgid "SHA-512 hash of certificate/key (more secure but longer)"
msgstr "Хеш SHA-512 сертификата/ключа (более безопасный, но длиннее)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:147
msgid ""
"How to encode the certificate data. SHA-256 (type 1) provides good balance "
"of security and length."
msgstr ""
"Как кодировать данные сертификата. SHA-256 (тип 1) обеспечивает хороший "
"баланс безопасности и длины."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:152
msgid "Certificate Data"
msgstr "Данные сертификата"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:156
msgid "Certificate Association Data"
msgstr "Данные ассоциации сертификата"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:161
msgid ""
"Hexadecimal hash or full certificate data (depending on matching type). For "
"SHA-256: use \"openssl x509 -in cert.pem -pubkey -noout | openssl pkey "
"-pubin -outform DER | openssl dgst -sha256\""
msgstr ""
"Шестнадцатеричный хеш или полные данные сертификата (в зависимости от типа "
"сопоставления). Для SHA-256: используйте \"openssl x509 -in cert.pem -pubkey "
"-noout | openssl pkey -pubin -outform DER | openssl dgst -sha256\""

#: lib/Module/DnsWizard/Service/SRVWizard.php:184
msgid "Record Settings"
msgstr "Настройки записи"

#: lib/Module/DnsWizard/Service/SRVWizard.php:188
msgid "TTL (seconds)"
msgstr "TTL (секунды)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:193
msgid "Time to live - how long DNS resolvers should cache this record"
msgstr "Время жизни - как долго DNS-резолверы должны кэшировать эту запись"

#: lib/Module/DnsWizard/Service/SRVWizard.php:289
msgid "Port must be between 1 and 65535"
msgstr "Порт должен быть между 1 и 65535"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:233
msgid "Usage must be 0, 1, 2, or 3"
msgstr "Использование должно быть 0, 1, 2 или 3"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:238
msgid "Selector must be 0 or 1"
msgstr "Селектор должен быть 0 или 1"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:243
msgid "Matching type must be 0, 1, or 2"
msgstr "Тип сопоставления должен быть 0, 1 или 2"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:248
msgid "Certificate association data is required"
msgstr "Данные ассоциации сертификата обязательны"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:253
msgid "Certificate data must be hexadecimal (0-9, a-f)"
msgstr "Данные сертификата должны быть шестнадцатеричными (0-9, a-f)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:259
#, php-format
msgid ""
"SHA-256 hash should be 64 hexadecimal characters, got %d. Verify the hash is "
"correct."
msgstr ""
"Хеш SHA-256 должен содержать 64 шестнадцатеричных символа, получено %d. "
"Проверьте правильность хеша."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:263
#, php-format
msgid ""
"SHA-512 hash should be 128 hexadecimal characters, got %d. Verify the hash "
"is correct."
msgstr ""
"Хеш SHA-512 должен содержать 128 шестнадцатеричных символов, получено %d. "
"Проверьте правильность хеша."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:267
msgid ""
"Full certificate data seems too short. Ensure you provided the complete "
"certificate."
msgstr ""
"Полные данные сертификата кажутся слишком короткими. Убедитесь, что вы "
"предоставили полный сертификат."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:274
#: templates/modern/edit.html:93 templates/modern/edit.html:667
msgid "Invalid hostname format"
msgstr "Недопустимый формат имени хоста"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:278
msgid ""
"CRITICAL: TLSA records require DNSSEC to be enabled on this zone. Without "
"DNSSEC, TLSA records provide NO security benefit."
msgstr ""
"КРИТИЧНО: Записи TLSA требуют включения DNSSEC в этой зоне. Без DNSSEC "
"записи TLSA НЕ обеспечивают никаких преимуществ безопасности."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:46
msgid "DMARC Record"
msgstr "Запись DMARC"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:47
msgid "Email authentication policy and reporting configuration"
msgstr "Политика аутентификации электронной почты и конфигурация отчетности"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:59
msgid "Policy Settings"
msgstr "Настройки политики"

#: lib/Module/DnsWizard/Service/SPFWizard.php:138
msgid "Policy"
msgstr "Политика"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:68
msgid "None (monitor only)"
msgstr "Нет (только мониторинг)"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:68
msgid "No action taken, just collect reports for analysis"
msgstr "Действие не предпринимается, только собираются отчеты для анализа"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:83
msgid "Quarantine"
msgstr "Карантин"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:69
msgid "Treat suspicious emails as spam/junk"
msgstr "Обрабатывать подозрительные письма как спам"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:84
msgid "Reject"
msgstr "Отклонить"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:70
msgid "Block delivery of suspicious emails entirely"
msgstr "Полностью блокировать доставку подозрительных писем"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:72
msgid "Start with \"none\" to collect data before enforcing a stricter policy."
msgstr ""
"Начните с \"нет\", чтобы собрать данные перед применением более строгой "
"политики."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:76
msgid "Subdomain Policy"
msgstr "Политика поддоменов"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:81
msgid "Same as domain policy"
msgstr "Такая же, как политика домена"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:81
msgid "Use the same policy as the main domain"
msgstr "Использовать ту же политику, что и для основного домена"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:82
msgid "None"
msgstr "Нет"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:82
msgid "Monitor only for subdomains"
msgstr "Только мониторинг для поддоменов"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:83
msgid "Quarantine suspicious subdomain emails"
msgstr "Помещать подозрительные письма поддоменов в карантин"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:84
msgid "Reject suspicious subdomain emails"
msgstr "Отклонять подозрительные письма поддоменов"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:86
msgid "Policy for emails from subdomains (e.g., mail.example.com)"
msgstr "Политика для писем из поддоменов (например, mail.example.com)"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:90
msgid "Policy Application Percentage"
msgstr "Процент применения политики"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:96
msgid ""
"Percentage of messages to which the policy should apply (100 = all "
"messages). Use lower values during policy rollout."
msgstr ""
"Процент сообщений, к которым должна применяться политика (100 = все "
"сообщения). Используйте более низкие значения во время развертывания "
"политики."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:101
msgid "Reporting Settings"
msgstr "Настройки отчетности"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:105
msgid "Aggregate Report Email"
msgstr "Email для сводного отчета"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:109
msgid "Email address to receive daily aggregate reports"
msgstr "Адрес электронной почты для получения ежедневных сводных отчетов"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:113
msgid "Forensic Report Email"
msgstr "Email для судебного отчета"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:117
msgid ""
"Email address to receive detailed failure reports (optional, can be high "
"volume)"
msgstr ""
"Адрес электронной почты для получения подробных отчетов об ошибках "
"(необязательно, может быть большой объем)"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:121
msgid "Forensic Reporting Options"
msgstr "Параметры судебной отчетности"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:125
msgid "Generate reports if all authentication mechanisms fail"
msgstr "Генерировать отчеты, если все механизмы аутентификации не прошли"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:126
msgid "Generate reports if any authentication mechanism fails"
msgstr "Генерировать отчеты, если какой-либо механизм аутентификации не прошел"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:127
msgid "Generate reports if DKIM check fails"
msgstr "Генерировать отчеты, если проверка DKIM не прошла"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:128
msgid "Generate reports if SPF check fails"
msgstr "Генерировать отчеты, если проверка SPF не прошла"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:130
msgid ""
"When to generate forensic reports (only applies if forensic email is set)"
msgstr ""
"Когда генерировать судебные отчеты (применяется только если установлен email "
"для судебных отчетов)"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:135
msgid "Alignment Settings"
msgstr "Настройки выравнивания"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:136
msgid "Advanced settings for SPF and DKIM alignment modes"
msgstr "Расширенные настройки для режимов выравнивания SPF и DKIM"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:140
msgid "DKIM Alignment Mode"
msgstr "Режим выравнивания DKIM"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:156
msgid "Relaxed"
msgstr "Ослабленный"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:145
msgid "DKIM domain can be subdomain of From: domain"
msgstr "Домен DKIM может быть поддоменом домена From:"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:157
msgid "Strict"
msgstr "Строгий"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:146
msgid "DKIM domain must exactly match From: domain"
msgstr "Домен DKIM должен точно соответствовать домену From:"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:151
msgid "SPF Alignment Mode"
msgstr "Режим выравнивания SPF"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:156
msgid "SPF domain can be subdomain of From: domain"
msgstr "Домен SPF может быть поддоменом домена From:"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:157
msgid "SPF domain must exactly match From: domain"
msgstr "Домен SPF должен точно соответствовать домену From:"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:261
msgid "Policy is required"
msgstr "Политика обязательна"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:263
msgid "Invalid policy value"
msgstr "Неверное значение политики"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:268
msgid "Invalid subdomain policy value"
msgstr "Неверное значение политики поддомена"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:275
msgid "Percentage must be between 0 and 100"
msgstr "Процент должен быть между 0 и 100"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:277
#, php-format
msgid ""
"Policy will only apply to %d%% of messages. Use 100%% once testing is "
"complete."
msgstr ""
"Политика будет применяться только к %d%% сообщений. Используйте 100%% после "
"завершения тестирования."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:283
msgid "Invalid aggregate report email address"
msgstr "Неверный адрес электронной почты для сводного отчета"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:287
msgid "Invalid forensic report email address"
msgstr "Неверный адрес электронной почты для судебного отчета"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:292
msgid ""
"No reporting email addresses configured. You will not receive DMARC reports."
msgstr ""
"Адреса электронной почты для отчетов не настроены. Вы не будете получать "
"отчеты DMARC."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:305
msgid ""
"Using \"p=none\" provides monitoring only. Consider stricter policy "
"(quarantine/reject) once you've reviewed reports."
msgstr ""
"Использование \"p=none\" обеспечивает только мониторинг. Рассмотрите более "
"строгую политику (карантин/отклонение) после просмотра отчетов."

#: lib/Module/DnsWizard/Service/SPFWizard.php:48
msgid "SPF Record"
msgstr "Запись SPF"

#: lib/Module/DnsWizard/Service/SPFWizard.php:49
msgid "Authorized mail server configuration"
msgstr "Конфигурация авторизованного почтового сервера"

#: lib/Module/DnsWizard/Service/SPFWizard.php:61
msgid "Basic Mechanisms"
msgstr "Основные механизмы"

#: lib/Module/DnsWizard/Service/SPFWizard.php:62
msgid "Select common mechanisms to authorize email sending"
msgstr "Выберите общие механизмы для авторизации отправки электронной почты"

#: lib/Module/DnsWizard/Service/SPFWizard.php:66
msgid "MX Records"
msgstr "Записи MX"

#: lib/Module/DnsWizard/Service/SPFWizard.php:69
msgid "Authorize all servers listed in MX records for this domain"
msgstr "Авторизовать все серверы, перечисленные в записях MX для этого домена"

#: lib/Module/DnsWizard/Service/SPFWizard.php:73
msgid "A/AAAA Records"
msgstr "Записи A/AAAA"

#: lib/Module/DnsWizard/Service/SPFWizard.php:76
msgid "Authorize the domain's A and AAAA records"
msgstr "Авторизовать записи A и AAAA домена"

#: lib/Module/DnsWizard/Service/SPFWizard.php:81
msgid "IP Addresses"
msgstr "IP-адреса"

#: lib/Module/DnsWizard/Service/SPFWizard.php:82
msgid "Authorized IP addresses and networks (CIDR notation supported)"
msgstr "Авторизованные IP-адреса и сети (поддерживается нотация CIDR)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:86
msgid "IPv4 Addresses"
msgstr "Адреса IPv4"

#: lib/Module/DnsWizard/Service/SPFWizard.php:90
msgid "One IP address or network per line (e.g., 192.0.2.1 or 192.0.2.0/24)"
msgstr ""
"Один IP-адрес или сеть на строку (например, 192.0.2.1 или 192.0.2.0/24)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:94
msgid "IPv6 Addresses"
msgstr "Адреса IPv6"

#: lib/Module/DnsWizard/Service/SPFWizard.php:98
msgid "One IPv6 address or network per line"
msgstr "Один адрес IPv6 или сеть на строку"

#: lib/Module/DnsWizard/Service/SPFWizard.php:103
msgid "Include Mechanisms"
msgstr "Механизмы включения"

#: lib/Module/DnsWizard/Service/SPFWizard.php:104
msgid "Include SPF records from other domains"
msgstr "Включить записи SPF из других доменов"

#: lib/Module/DnsWizard/Service/SPFWizard.php:108
msgid "Include Domains"
msgstr "Включить домены"

#: lib/Module/DnsWizard/Service/SPFWizard.php:112
msgid ""
"Domains whose SPF records should be included (one per line). Common: "
"_spf.google.com, spf.protection.outlook.com"
msgstr ""
"Домены, чьи записи SPF должны быть включены (по одному на строку). Общие: "
"_spf.google.com, spf.protection.outlook.com"

#: lib/Module/DnsWizard/Service/SPFWizard.php:117
msgid "Additional Mechanisms"
msgstr "Дополнительные механизмы"

#: lib/Module/DnsWizard/Service/SPFWizard.php:121
msgid "Additional A/AAAA Hosts"
msgstr "Дополнительные хосты A/AAAA"

#: lib/Module/DnsWizard/Service/SPFWizard.php:125
msgid "Authorize specific hostnames' A/AAAA records (one per line)"
msgstr ""
"Авторизовать записи A/AAAA определенных имен хостов (по одной на строку)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:129
msgid "Additional MX Hosts"
msgstr "Дополнительные хосты MX"

#: lib/Module/DnsWizard/Service/SPFWizard.php:133
msgid "Authorize MX records from other domains (one per line)"
msgstr "Авторизовать записи MX из других доменов (по одной на строку)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:142
msgid "Default Action"
msgstr "Действие по умолчанию"

#: lib/Module/DnsWizard/Service/SPFWizard.php:147
msgid "Pass all - allows anyone to send (insecure)"
msgstr "Пропустить все - разрешает любому отправлять (небезопасно)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:148
msgid "Neutral (no policy)"
msgstr "Нейтральный (нет политики)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:149
msgid "Soft fail (mark as spam but accept)"
msgstr "Мягкий сбой (пометить как спам, но принять)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:150
msgid "Fail (reject unauthorized emails)"
msgstr "Сбой (отклонить неавторизованные письма)"

#: lib/Module/DnsWizard/Service/SPFWizard.php:152
msgid ""
"Policy for emails not matching any mechanism. Start with ~all (softfail) for "
"testing."
msgstr ""
"Политика для писем, не соответствующих ни одному механизму. Начните с ~all "
"(softfail) для тестирования."

#: lib/Module/DnsWizard/Service/SPFWizard.php:289
#, php-format
msgid ""
"SPF record exceeds the DNS lookup limit (%d/10). This will cause SPF "
"validation to fail. Remove some include/a/mx mechanisms or use ip4/ip6 "
"instead."
msgstr ""
"Запись SPF превышает лимит поиска DNS (%d/10). Это приведет к сбою проверки "
"SPF. Удалите некоторые механизмы include/a/mx или используйте ip4/ip6 вместо "
"них."

#: lib/Module/DnsWizard/Service/SPFWizard.php:294
#, php-format
msgid ""
"SPF record has %d DNS lookups (limit is 10). Consider using ip4/ip6 instead "
"of include mechanisms, or consolidate includes to stay under the limit."
msgstr ""
"Запись SPF имеет %d поисков DNS (лимит 10). Рассмотрите использование ip4/"
"ip6 вместо механизмов include или объедините include, чтобы остаться в "
"пределах лимита."

#: lib/Module/DnsWizard/Service/SPFWizard.php:304
#, php-format
msgid "Invalid IPv4 address or network: %s"
msgstr "Неверный адрес IPv4 или сеть: %s"

#: lib/Module/DnsWizard/Service/SPFWizard.php:313
#, php-format
msgid "Invalid IPv6 address or network: %s"
msgstr "Неверный адрес IPv6 или сеть: %s"

#: lib/Module/DnsWizard/Service/SPFWizard.php:323
#, php-format
msgid "Invalid include domain: %s"
msgstr "Неверный домен include: %s"

#: lib/Module/DnsWizard/Service/SPFWizard.php:343
msgid ""
"No mechanisms selected. This SPF record will only contain the default action."
msgstr ""
"Механизмы не выбраны. Эта запись SPF будет содержать только действие по "
"умолчанию."

#: lib/Module/DnsWizard/Service/SPFWizard.php:348
msgid ""
"Using \"+all\" allows anyone to send email as your domain. This is strongly "
"discouraged."
msgstr ""
"Использование \"+all\" разрешает любому отправлять электронную почту от "
"имени вашего домена. Это настоятельно не рекомендуется."

#: lib/Module/DnsWizard/Service/CAAWizard.php:43
msgid "CAA Record"
msgstr "Запись CAA"

#: lib/Module/DnsWizard/Service/CAAWizard.php:44
msgid "Certificate authority authorization"
msgstr "Авторизация центра сертификации"

#: lib/Module/DnsWizard/Service/CAAWizard.php:68
msgid "Custom (enter manually)"
msgstr "Пользовательский (ввести вручную)"

#: lib/Module/DnsWizard/Service/CAAWizard.php:74
msgid "Certificate Authority"
msgstr "Центр сертификации"

#: lib/Module/DnsWizard/Service/CAAWizard.php:78
msgid "CA Provider"
msgstr "Поставщик CA"

#: lib/Module/DnsWizard/Service/CAAWizard.php:83
msgid ""
"Select the certificate authority authorized to issue certificates for this "
"domain"
msgstr ""
"Выберите центр сертификации, уполномоченный выдавать сертификаты для этого "
"домена"

#: lib/Module/DnsWizard/Service/CAAWizard.php:87
msgid "CA Domain (Custom)"
msgstr "Домен CA (Пользовательский)"

#: lib/Module/DnsWizard/Service/CAAWizard.php:92
msgid ""
"Enter the CA domain name manually (only shown when \"Custom\" is selected)"
msgstr ""
"Введите имя домена CA вручную (показывается только когда выбран "
"\"Пользовательский\")"

#: lib/Module/DnsWizard/Service/CAAWizard.php:97
msgid "Certificate Type"
msgstr "Тип сертификата"

#: lib/Module/DnsWizard/Service/CAAWizard.php:101
#: templates/modern/dnssec_delete_key.html:82
msgid "Tag"
msgstr "Тег"

#: lib/Module/DnsWizard/Service/CAAWizard.php:106
msgid "Issue"
msgstr "Выдача"

#: lib/Module/DnsWizard/Service/CAAWizard.php:106
msgid "Authorize issuance of standard certificates"
msgstr "Авторизовать выдачу стандартных сертификатов"

#: lib/Module/DnsWizard/Service/CAAWizard.php:107
msgid "Issue Wildcard"
msgstr "Выдача Wildcard"

#: lib/Module/DnsWizard/Service/CAAWizard.php:107
msgid "Authorize issuance of wildcard certificates (*.example.com)"
msgstr "Авторизовать выдачу wildcard-сертификатов (*.example.com)"

#: lib/Module/DnsWizard/Service/CAAWizard.php:108
msgid "Incident Reporting"
msgstr "Отчеты об инцидентах"

#: lib/Module/DnsWizard/Service/CAAWizard.php:108
msgid "URL to report certificate issuance violations"
msgstr "URL для сообщения о нарушениях выдачи сертификатов"

#: lib/Module/DnsWizard/Service/CAAWizard.php:110
msgid "Type of authorization or reporting"
msgstr "Тип авторизации или отчетности"

#: lib/Module/DnsWizard/Service/CAAWizard.php:114
msgid "Reporting URL"
msgstr "URL отчетности"

#: lib/Module/DnsWizard/Service/CAAWizard.php:119
msgid "URL or email for incident reports (mailto: or https:)"
msgstr "URL или email для отчетов об инцидентах (mailto: или https:)"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:103
msgid "Advanced Options"
msgstr "Расширенные параметры"

#: lib/Module/DnsWizard/Service/CAAWizard.php:130
msgid "Flags"
msgstr "Флаги"

#: lib/Module/DnsWizard/Service/CAAWizard.php:135
msgid "Non-critical"
msgstr "Некритичный"

#: lib/Module/DnsWizard/Service/CAAWizard.php:135
msgid "Allow fallback if not understood"
msgstr "Разрешить резервный вариант, если не понят"

#: lib/Module/DnsWizard/Service/CAAWizard.php:136
msgid "Critical"
msgstr "Критичный"

#: lib/Module/DnsWizard/Service/CAAWizard.php:136
msgid "Reject if not understood - strict enforcement"
msgstr "Отклонить, если не понят - строгое применение"

#: lib/Module/DnsWizard/Service/CAAWizard.php:138
msgid ""
"Non-critical (0) provides better compatibility. Critical (128) enforces "
"strict CAA processing."
msgstr ""
"Некритичный (0) обеспечивает лучшую совместимость. Критичный (128) "
"обеспечивает строгую обработку CAA."

#: lib/Module/DnsWizard/Service/CAAWizard.php:204
msgid "Invalid CAA tag. Must be issue, issuewild, or iodef"
msgstr "Неверный тег CAA. Должен быть issue, issuewild или iodef"

#: lib/Module/DnsWizard/Service/CAAWizard.php:210
msgid "CA provider is required"
msgstr "Поставщик CA обязателен"

#: lib/Module/DnsWizard/Service/CAAWizard.php:213
msgid "Custom CA domain is required when \"Custom\" is selected"
msgstr ""
"Пользовательский домен CA обязателен, когда выбран \"Пользовательский\""

#: lib/Module/DnsWizard/Service/CAAWizard.php:215
msgid "Invalid CA domain format"
msgstr "Неверный формат домена CA"

#: lib/Module/DnsWizard/Service/CAAWizard.php:221
msgid ""
"Using \";\" allows ALL certificate authorities to issue certificates. This "
"defeats the purpose of CAA records."
msgstr ""
"Использование \";\" разрешает ВСЕМ центрам сертификации выдавать "
"сертификаты. Это сводит на нет цель записей CAA."

#: lib/Module/DnsWizard/Service/CAAWizard.php:227
msgid "Reporting URL is required for iodef tag"
msgstr "URL отчетности обязателен для тега iodef"

#: lib/Module/DnsWizard/Service/CAAWizard.php:229
#, php-format
msgid "Reporting URL must start with %s, %s, or %s"
msgstr "URL отчетности должен начинаться с %s, %s или %s"

#: lib/Module/DnsWizard/Service/CAAWizard.php:236
msgid "Flags must be 0 or 128"
msgstr "Флаги должны быть 0 или 128"

#: lib/Module/DnsWizard/Service/CAAWizard.php:240
msgid ""
"Critical flag (128) is set. Systems that do not understand CAA records will "
"reject operations. Use 0 unless you have a specific requirement."
msgstr ""
"Установлен критичный флаг (128). Системы, которые не понимают записи CAA, "
"будут отклонять операции. Используйте 0, если у вас нет специального "
"требования."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:46
msgid "DKIM Record"
msgstr "Запись DKIM"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:47
msgid "Email signature verification public key"
msgstr "Открытый ключ проверки подписи электронной почты"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:58
#: templates/modern/dnssec_edit_key.html:51
msgid "Information"
msgstr "Информация"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:61
msgid ""
"DKIM proves emails are from your domain using cryptographic signatures. "
"Generate the DKIM key pair on your MAIL SERVER (Postfix, Exim, etc.). Only "
"the PUBLIC KEY goes in this DNS record. Keep the PRIVATE KEY secure on your "
"mail server (never share it)."
msgstr ""
"DKIM доказывает, что письма от вашего домена, используя криптографические "
"подписи. Сгенерируйте пару ключей DKIM на вашем ПОЧТОВОМ СЕРВЕРЕ (Postfix, "
"Exim и т.д.). Только ОТКРЫТЫЙ КЛЮЧ попадает в эту DNS-запись. Храните "
"ЗАКРЫТЫЙ КЛЮЧ в безопасности на вашем почтовом сервере (никогда не делитесь "
"им)."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:68
msgid "DKIM Configuration"
msgstr "Конфигурация DKIM"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:77
msgid ""
"Selector to identify the DKIM key (commonly \"default\", timestamp like "
"\"202501\", or service name like \"google\"). Only alphanumeric characters, "
"hyphens, and underscores allowed."
msgstr ""
"Селектор для идентификации ключа DKIM (обычно \"default\", временная метка "
"вроде \"202501\" или имя службы вроде \"google\"). Разрешены только буквенно-"
"цифровые символы, дефисы и подчеркивания."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:81
msgid "Public Key"
msgstr "Открытый ключ"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:86
msgid ""
"Paste the base64-encoded public key from your mail server. Spaces and "
"newlines will be automatically removed."
msgstr ""
"Вставьте открытый ключ в кодировке base64 с вашего почтового сервера. "
"Пробелы и новые строки будут автоматически удалены."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:90
msgid "Key Type"
msgstr "Тип ключа"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:95
msgid "Widely supported by all mail servers"
msgstr "Широко поддерживается всеми почтовыми серверами"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:96
msgid "Newer algorithm - not universally supported yet"
msgstr "Новый алгоритм - пока не поддерживается повсеместно"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:98
msgid "Encryption algorithm for the DKIM public key"
msgstr "Алгоритм шифрования для открытого ключа DKIM"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:109
msgid "Testing Mode"
msgstr "Режим тестирования"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:112
msgid ""
"Enable testing mode (t=y). DKIM signatures will be present but not enforced. "
"Use during initial deployment."
msgstr ""
"Включить режим тестирования (t=y). Подписи DKIM будут присутствовать, но не "
"будут применяться. Используйте во время начального развертывания."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:116
msgid "Strict Subdomain Mode"
msgstr "Режим строгих поддоменов"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:119
msgid ""
"Enable strict subdomain mode (t=s). Rejects unsigned mail from subdomains."
msgstr ""
"Включить режим строгих поддоменов (t=s). Отклоняет неподписанную почту из "
"поддоменов."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:198
msgid "Selector is required"
msgstr "Селектор обязателен"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:200
msgid ""
"Selector can only contain alphanumeric characters, hyphens, and underscores"
msgstr ""
"Селектор может содержать только буквенно-цифровые символы, дефисы и "
"подчеркивания"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:205
msgid "Public key is required"
msgstr "Открытый ключ обязателен"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:211
msgid "Public key must be valid base64-encoded data"
msgstr "Открытый ключ должен быть действительными данными в кодировке base64"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:216
msgid ""
"Public key seems unusually short. Ensure you copied the complete key from "
"your mail server."
msgstr ""
"Открытый ключ кажется необычно коротким. Убедитесь, что вы скопировали "
"полный ключ с вашего почтового сервера."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:221
msgid ""
"You pasted a PRIVATE KEY. Only the PUBLIC KEY should be in DNS. Never share "
"your private key!"
msgstr ""
"Вы вставили ЗАКРЫТЫЙ КЛЮЧ. Только ОТКРЫТЫЙ КЛЮЧ должен быть в DNS. Никогда "
"не делитесь своим закрытым ключом!"

#: lib/Module/DnsWizard/Service/DKIMWizard.php:225
msgid ""
"Public key appears to contain PEM headers (BEGIN/END). Only the base64 "
"content between headers is needed."
msgstr ""
"Открытый ключ, похоже, содержит заголовки PEM (BEGIN/END). Нужно только "
"содержимое base64 между заголовками."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:239
msgid ""
"Testing mode is enabled (t=y). DKIM signatures will not be enforced. Disable "
"this once testing is complete."
msgstr ""
"Режим тестирования включен (t=y). Подписи DKIM не будут применяться. "
"Отключите это после завершения тестирования."

#: lib/Module/DnsWizard/Service/SRVWizard.php:68
msgid "SRV Record"
msgstr "Запись SRV"

#: lib/Module/DnsWizard/Service/SRVWizard.php:69
msgid "Service location (hostname and port)"
msgstr "Расположение службы (имя хоста и порт)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:95
msgid "Service"
msgstr "Служба"

#: lib/Module/DnsWizard/Service/SRVWizard.php:100
msgid "Select a common service or choose \"Custom\" to enter manually"
msgstr ""
"Выберите общую службу или выберите \"Пользовательский\" для ввода вручную"

#: lib/Module/DnsWizard/Service/SRVWizard.php:104
msgid "Custom Service Name"
msgstr "Пользовательское имя службы"

#: lib/Module/DnsWizard/Service/SRVWizard.php:109
msgid "Service name must start with underscore (e.g., _myservice)"
msgstr "Имя службы должно начинаться с подчеркивания (например, _myservice)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:118
msgid "Transmission Control Protocol - most common"
msgstr "Transmission Control Protocol - наиболее распространен"

#: lib/Module/DnsWizard/Service/SRVWizard.php:119
msgid "User Datagram Protocol - connectionless"
msgstr "User Datagram Protocol - без установления соединения"

#: lib/Module/DnsWizard/Service/SRVWizard.php:120
msgid "Transport Layer Security"
msgstr "Transport Layer Security"

#: lib/Module/DnsWizard/Service/SRVWizard.php:123
msgid "Transport protocol for the service"
msgstr "Транспортный протокол для службы"

#: lib/Module/DnsWizard/Service/SRVWizard.php:127
#: templates/modern/dnssec_delete_key.html:52
msgid "Domain"
msgstr "Домен"

#: lib/Module/DnsWizard/Service/SRVWizard.php:131
msgid ""
"Domain name (leave empty for zone apex @). Full record name will be: "
"_service._protocol.domain"
msgstr ""
"Имя домена (оставьте пустым для вершины зоны @). Полное имя записи будет: "
"_служба._протокол.домен"

#: lib/Module/DnsWizard/Service/SRVWizard.php:136
msgid "Target Server"
msgstr "Целевой сервер"

#: lib/Module/DnsWizard/Service/SRVWizard.php:140
msgid "Target Hostname"
msgstr "Целевое имя хоста"

#: lib/Module/DnsWizard/Service/SRVWizard.php:144
msgid ""
"Hostname of the server providing this service (must be a hostname with an A/"
"AAAA record, not an IP address)"
msgstr ""
"Имя хоста сервера, предоставляющего эту службу (должно быть именем хоста с "
"записью A/AAAA, а не IP-адресом)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:154
msgid ""
"Port number where the service is listening (automatically filled for common "
"services)"
msgstr ""
"Номер порта, на котором прослушивается служба (автоматически заполняется для "
"общих служб)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:159
msgid "Priority & Load Balancing"
msgstr "Приоритет и балансировка нагрузки"

#: lib/Module/DnsWizard/Service/SRVWizard.php:163
#: lib/Module/ZoneImportExport/templates/import.html:82
msgid "Priority"
msgstr "Приоритет"

#: lib/Module/DnsWizard/Service/SRVWizard.php:169
msgid ""
"Lower values have higher priority (10 is a good default). Clients try "
"servers in priority order."
msgstr ""
"Более низкие значения имеют более высокий приоритет (10 - хорошее значение "
"по умолчанию). Клиенты пробуют серверы в порядке приоритета."

#: lib/Module/DnsWizard/Service/SRVWizard.php:173
msgid "Weight"
msgstr "Вес"

#: lib/Module/DnsWizard/Service/SRVWizard.php:179
msgid ""
"For load balancing among servers with same priority. Higher weight = more "

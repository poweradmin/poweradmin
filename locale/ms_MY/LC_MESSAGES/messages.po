msgid "NAPTR record preference must be a number between 0 and 65535."
msgstr "preferensi rekaman HANAPTR harus berupa angka antara 0 dan 65535."

#: lib/Domain/Service/DnsValidation/NAPTRRecordValidator.php:219
msgid "NAPTR record flags must be a quoted string."
msgstr "Bendera rekaman NAPTR harus berupa string yang dikutip."

#: lib/Domain/Service/DnsValidation/NAPTRRecordValidator.php:225
msgid "NAPTR record flags must contain only A, P, S, or U."
msgstr "Bendera rekaman NAPTR harus hanya berisi A, P, S, atau U."


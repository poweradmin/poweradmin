msgstr ""
"Zestaw znakow (kodowanie), ktory bedzie uzywany dla nowych tabel. Pozostaw puste, aby uzyc domyslnego zestawu znakow bazy danych."

#: install/templates/step3.html.twig:93
msgid "DB collation"
msgstr "Porównywanie DB"

#: install/templates/step3.html.twig:99

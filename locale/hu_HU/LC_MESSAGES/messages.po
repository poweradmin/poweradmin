msgstr ""
"SRV record content must have weight, port and target (3 fields). Priority "
"should be in the priority field."

#: lib/Domain/Service/DnsValidation/SRVRecordValidator.php:345
#, php-format
msgid ""
"Port %d differs from the standard port %d for %s service. This is allowed "
"but unusual."
msgstr ""

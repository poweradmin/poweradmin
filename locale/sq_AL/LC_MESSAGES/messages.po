msgstr "Objektivi duhet të jetë një emërues, jo një adresë IP. Krijo fillimisht një rekord A ose AAA për emrin e host."

#: lib/Module/DnsWizard/Service/SRVWizard.php:295
msgid "Priority must be between 0 and 65535"
msgstr "Prioriteti duhet të jetë midis 0 dhe 65535"

#: lib/Module/DnsWizard/Service/SRVWizard.php:299
msgid ""
"Priority 0 is valid but unusual. Most services use priority 10 or higher."
msgstr "Prioriteti 0 është i vlefshëm, por i pazakontë. Shumica e shërbimeve përdorin përparësinë 10 ose më të lartë."

#: lib/Module/DnsWizard/Service/SRVWizard.php:305
msgid "Weight must be between 0 and 65535"
msgstr "Pesha duhet të jetë midis 0 dhe 65535"


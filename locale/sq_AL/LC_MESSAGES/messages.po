msgstr "Format i pavlefshëm SRV. Emri"

#: lib/Domain/Service/DatabaseSchemaService.php:55
msgid "Unknown database type."
msgstr "Lloj i panjohur i të dhënave."

#: lib/Domain/Service/ReverseRecordCreator.php:91
#, php-format
msgid "There is no matching reverse-zone for: %s."
msgstr "Nuk ka zonë të kundërt përkatëse për: %s."

#: lib/Domain/Service/ReverseRecordCreator.php:99
#, php-format
msgid "A PTR record for %s pointing to %s already exists."
msgstr "Një rekord PTR për %s që tregon për %s tashmë ekziston."

#: lib/Domain/Service/ReverseRecordCreator.php:112

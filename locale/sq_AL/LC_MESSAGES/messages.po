msgstr "Fillo me \"asnjë\" për të mbledhur të dhëna përpara se të zbatosh një politikë më të rreptë."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:76
msgid "Subdomain Policy"
msgstr "Politika bazë"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:81
msgid "Same as domain policy"
msgstr "E njëjta si politika domain"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:81
msgid "Use the same policy as the main domain"
msgstr "Përdor të njëjtën politikë si domain kryesor"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:82
msgid "None"
msgstr "Asnjë"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:82

msgstr "Asnjë veprim i ndërmarrë, vetëm mblidh raportet për analizë."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:83
msgid "Quarantine"
msgstr "Quarantine"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:69

msgstr "Nevoitet emri i personalizuar i shërbimit"

#: lib/Module/DnsWizard/Service/SRVWizard.php:267
msgid "Service name must contain only alphanumeric characters and hyphens"
msgstr "Emri i shërbimit duhet të përmbajë vetëm shkronja dhe hifrone alfamerike"

#: lib/Module/DnsWizard/Service/SRVWizard.php:273
msgid "Target hostname is required"
msgstr "Nevoitet emri i host"

#: lib/Module/DnsWizard/Service/SRVWizard.php:277
msgid "Invalid target hostname format"
msgstr "Format i pavlefshëm emri i host"

#: lib/Module/DnsWizard/Service/SRVWizard.php:282

msgstr "Kërkohet URL e raportimit për etiketën jodef"

#: lib/Module/DnsWizard/Service/CAAWizard.php:229
#, php-format
msgid "Reporting URL must start with %s, %s, or %s"
msgstr "URL-ja e raportimit duhet të fillojë me %s, %s, ose %s"


#: lib/Module/DnsWizard/Service/TLSAWizard.php:45
msgid "TLSA Record"
msgstr "Regjistri TLSA"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:46
msgid "TLS certificate/key authentication (DANE)"
msgstr "Identifikimi dështoi"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:57
msgid "DNSSEC Requirement"
msgstr "Kërkesa DNSSEC"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:59
msgid ""
"TLSA records require DNSSEC to be enabled for this zone. TLSA records "
"without DNSSEC will not provide security benefits and may be ignored by "
"clients."
msgstr "Të dhënat TLSA kërkojnë që DNSSEC të aktivizohet për këtë zonë. Të dhënat TLSA pa DNSSEC nuk do të ofrojnë përfitime sigurie dhe mund të shpërfillen nga klientët."

#: lib/Module/DnsWizard/Service/SRVWizard.php:91
msgid "Service Configuration"
msgstr "Konfigurimi i shërbimit"

#: lib/Module/DnsWizard/Service/SRVWizard.php:148
msgid "Port Number"
msgstr "Porta Numri"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:72
msgid ""
"TCP/UDP port number (443 for HTTPS, 25 for SMTP, 853 for DNS-over-TLS, etc.)"
msgstr "TCP/UDP numër (443 për HTTP, 25 për SMTP, 853 për DNS-over-TLS, etj.)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:113
msgid "Protocol"
msgstr "Protokolli"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:81
msgid "Transmission Control Protocol - most common for HTTPS/TLS"
msgstr "Protokolli i Kontrollit të Transmetimit - Më i zakonshmi për HTTP/TLS"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:82
msgid "User Datagram Protocol - for DTLS connections"
msgstr "Protokolli i të dhënave të përdoruesit - për lidhjet DTLS"

#: lib/Module/DnsWizard/Service/SRVWizard.php:121
msgid "Stream Control Transmission Protocol"
msgstr "Protokolli i Transmetimit të Kontrollit Rrjedhak"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:85
msgid "Transport protocol for the TLS connection"
msgstr "Protokolli i transportit për lidhjen TLS"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:89
#: install/templates/step4.html.twig:140
msgid "Hostname"
msgstr "Emri i host"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:93
msgid ""
"Hostname for the service (leave empty for zone apex @). Record will be "
"created at _port._protocol.hostname"
msgstr "Emri i host për shërbimin (lejo bosh për zonën apex @). Regjistri do të krijohet tek  port. protocol.stame"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:98
msgid "Certificate Usage"
msgstr "Përdorimi i çertifikatës"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:102
msgid "Usage"
msgstr "Përdorimi"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:107
msgid "0 - CA Constraint"
msgstr "0 - CA Constraint"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:107
msgid "Certificate must chain to specified CA (PKIX-TA)"
msgstr "Çertifikata duhet të lidhet me CA të specifikuar (PIX-TA)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:108
msgid "1 - Service Certificate"
msgstr "Çertifikata e shërbimit"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:108
msgid "Certificate must match exactly (PKIX-EE)"
msgstr "Çertifikata duhet të korrispondon saktësisht (PIX-EE)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:109
msgid "2 - Trust Anchor Assertion"
msgstr "2 - Besimi te shembulli i lidhjeve"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:109
msgid "Certificate must chain to specified anchor (DANE-TA)"
msgstr "Çertifikata duhet të lidhet me spirancën e specifikuar (DANE-TA)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:110
msgid "3 - Domain-Issued Certificate"
msgstr "3 - Certifikata Domain-Isued"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:110
msgid "Certificate must match exactly, bypassing PKI (DANE-EE)"
msgstr "Çertifikata duhet të korrispondon saktësisht, duke anashkaluar PKI (DANE-EE)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:112
msgid ""
"How the certificate should be validated. Type 3 is most common for self-"
"signed or custom CAs."
msgstr "Se si duhet të zbatohet çertifikata. Lloji 3 është më i zakonshëm për vetë-nënshkruar apo i personalizuar CAs."

#: lib/Module/DnsWizard/Service/DKIMWizard.php:72
msgid "Selector"
msgstr "Zgjedhësi"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:126
msgid "0 - Full Certificate"
msgstr "Çertifikata e plotë 0"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:126
msgid "Use the entire certificate"
msgstr "Përdor të gjithë çertifikatën"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:127
msgid "1 - Public Key"
msgstr "1 - Kyçi publik"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:127
msgid "Use only the Subject Public Key Info (SPKI)"
msgstr "Informacionet e kyçit publik të subjektit"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:129
msgid ""
"What part of the certificate to match. Type 1 (public key) survives "
"certificate renewal."
msgstr "Cila pjesë e certifikatës për tu përshtatur. Lloji 1 ( kyçi publik) mbijeton gjatë përtëritjes së certifikatës."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:138
msgid "Matching Type"
msgstr "Lloji"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:143
msgid "0 - Exact Match"
msgstr "Korrispondencë e saktë"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:143
msgid "Full certificate/key data (very long record)"
msgstr "Çertifikata e plotë"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:144
msgid "1 - SHA-256 Hash"
msgstr "1 - SHA-256 Hash"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:144
msgid "SHA-256 hash of certificate/key"
msgstr "Hash i çertifikatës/kesë SHA-256"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:145
msgid "2 - SHA-512 Hash"
msgstr "2 - SHA-1 Hash"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:145
msgid "SHA-512 hash of certificate/key (more secure but longer)"
msgstr "SHA-512 hash of çertifikate (më i sigurt por më i gjatë)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:147
msgid ""
"How to encode the certificate data. SHA-256 (type 1) provides good balance "
"of security and length."
msgstr "Si t'i kodosh të dhënat e çertifikatës. SHA-256 (type 1) siguron ekuilibër të mirë të sigurisë dhe gjatësisë."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:152
msgid "Certificate Data"
msgstr "Çertifikata"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:156
msgid "Certificate Association Data"
msgstr "Shoqata e çertifikatave"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:161
msgid ""
"Hexadecimal hash or full certificate data (depending on matching type). For "
"SHA-256: use \"openssl x509 -in cert.pem -pubkey -noout | openssl pkey "
"-pubin -outform DER | openssl dgst -sha256\""
msgstr "Hexadecimal hash ose të dhëna të plota çertifikate (duke u varur nga lloji korrespondues). Për SHA-256: përdorimi i \"hapësit x509 - in cert.pem -pubkey -noutslel pock -pubin-outform PPER'sl dgst -sha256\""

#: lib/Module/DnsWizard/Service/SRVWizard.php:184
msgid "Record Settings"
msgstr "Rregullimet audio"

#: lib/Module/DnsWizard/Service/SRVWizard.php:188
msgid "TTL (seconds)"
msgstr "TTL (sekonda)"

#: lib/Module/DnsWizard/Service/SRVWizard.php:193
msgid "Time to live - how long DNS resolvers should cache this record"
msgstr "Koha për të jetuar - Për sa kohë do të duhet ta ruajnë vendimin e DNS - së këtë regjistrim"

#: lib/Module/DnsWizard/Service/SRVWizard.php:289
msgid "Port must be between 1 and 65535"
msgstr "Porti duhet të jetë midis 1 dhe 65535"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:233
msgid "Usage must be 0, 1, 2, or 3"
msgstr "Përdorimi duhet të jetë 0, 1, 2, ose 3"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:238
msgid "Selector must be 0 or 1"
msgstr "Zgjedhësi duhet të jetë 0 ose 1"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:243
msgid "Matching type must be 0, 1, or 2"
msgstr "lloji"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:248
msgid "Certificate association data is required"
msgstr "Nevoitet e dhëna e shoqërimit të çertifikatës"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:253
msgid "Certificate data must be hexadecimal (0-9, a-f)"
msgstr "Çertifikata duhet të jetë hexadecimal (0-9, a-f)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:259
#, php-format
msgid ""
"SHA-256 hash should be 64 hexadecimal characters, got %d. Verify the hash is"
" correct."
msgstr "Hash-i SHA-256 duhet të ketë 64 karaktere heksadecimale, u morën %d. Verifikoni që hash-i është i saktë."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:263
#, php-format
msgid ""
"SHA-512 hash should be 128 hexadecimal characters, got %d. Verify the hash "
"is correct."
msgstr "Hash-i SHA-512 duhet të ketë 128 karaktere heksadecimale, u morën %d. Verifikoni që hash-i është i saktë."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:267
msgid ""
"Full certificate data seems too short. Ensure you provided the complete "
"certificate."
msgstr "Të dhënat e plota të çertifikatës duken tepër të shkurtra. Sigurohu që ke dhënë çertifikatën e plotë."

#: lib/Module/DnsWizard/Service/TLSAWizard.php:274
#: templates/modern/edit.html:93 templates/modern/edit.html:673
msgid "Invalid hostname format"
msgstr "Format i pavlefshëm emri i host"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:278
msgid ""
"CRITICAL: TLSA records require DNSSEC to be enabled on this zone. Without "
"DNSSEC, TLSA records provide NO security benefit."
msgstr "CRITIKE: Të dhënat TLSA kërkojnë që DNSSEC të aktivizohet në këtë zonë. Pa DNSSEC, të dhënat e TLSA-së nuk sigurojnë përfitim sigurie."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:46
msgid "DMARC Record"
msgstr "Regjistri DMARC"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:47

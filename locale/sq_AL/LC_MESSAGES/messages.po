msgid "Updating database... done!"
msgstr "Duke rifreskuar databazën... u krye!"

#: install/helpers/InstallStepHandler.php:207
msgid "Foreign Key Constraint Issues:"
msgstr "Çështjet kryesore të huaja:"

#: install/helpers/InstallStepHandler.php:209
msgid ""
"The installer could not remove existing tables due to foreign key "
"constraints"
msgstr "Instaluesi nuk mund të heqë tabelat ekzistuese për shkak të kufizimeve të huaja kyçe"

#: install/helpers/InstallStepHandler.php:210
msgid ""
"This can happen during reinstallation if you have custom constraints or if "
"tables are referenced by other tables"
msgstr "Kjo mund të ndodhë gjatë rivendosjes nëse keni kufizime doganore ose nëse tavolinat përmenden nga tryeza të tjera"

#: install/helpers/InstallStepHandler.php:211
msgid ""
"You can try manually disabling foreign key checks before running the "
"installer:"
msgstr "Mund të përpiqeni manualisht të çaktivizoni kontrollet e kyçeve të huaj para se të kryeni instalimin:"

#: install/helpers/InstallStepHandler.php:224
msgid "Suggestions:"
msgstr "Propozime:"

#: install/helpers/InstallStepHandler.php:218
msgid "Make sure the SQLite database file exists"
msgstr "Sigurohu që file me bazë databazë SQLite të ekzistojë"

#: install/helpers/InstallStepHandler.php:219
msgid ""
"Check that the web server has read and write permissions for the database "
"file"
msgstr "Kontrollo që serveri web ka lexuar dhe shkruar të drejtat për file bazë"

#: install/helpers/InstallStepHandler.php:220
msgid "Verify the full path to the database file is correct and accessible"
msgstr "Kontrolli shtegu është"

#: install/helpers/InstallStepHandler.php:226
msgid "Verify database credentials are correct"
msgstr "Kontrollo që kredencialet për databazën janë korrekte"

#: install/helpers/InstallStepHandler.php:227
msgid "Check that the database user has sufficient privileges"
msgstr "Kontrollo që përdoruesi i bazës së të dhënave ka privilegje të mjaftueshme"

#: install/helpers/InstallStepHandler.php:228
msgid "Ensure the database server is running and accessible"
msgstr "Sigurohu që serveri i databazës të jetë në ekzekutim dhe të jetë i arritshëm"


msgstr "0 - بازی دقیق"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:143
msgid "Full certificate/key data (very long record)"
msgstr "اطلاعات کامل گواهی / کلید (بسیار طولانی)"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:144
msgid "1 - SHA-256 Hash"
msgstr "1 - هش SHA-256"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:144
msgid "SHA-256 hash of certificate/key"
msgstr "هش SHA-256 گواهی/key"

#: lib/Module/DnsWizard/Service/TLSAWizard.php:145
msgid "2 - SHA-512 Hash"
msgstr "2 - هش SHA-512"


msgid "Service is required"
msgstr "Απαιτείται υπηρεσία"

#: lib/Module/DnsWizard/Service/SRVWizard.php:265
msgid "Custom service name is required"
msgstr "Απαιτείται προσαρμοσμένο όνομα υπηρεσίας"

#: lib/Module/DnsWizard/Service/SRVWizard.php:267
msgid "Service name must contain only alphanumeric characters and hyphens"
msgstr "Το όνομα υπηρεσίας πρέπει να περιέχει μόνο αλφαριθμητικούς χαρακτήρες και παύλα"


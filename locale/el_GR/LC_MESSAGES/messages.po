msgstr "Ποσοστό μηνυμάτων στα οποία πρέπει να εφαρμόζεται η πολιτική (100 = όλα τα μηνύματα). Χρήση χαμηλότερων τιμών κατά τη διάρκεια της εφαρμογής της πολιτικής."

#: lib/Module/DnsWizard/Service/DMARCWizard.php:101
msgid "Reporting Settings"
msgstr "Settings αναφοράς"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:105
msgid "Aggregate Report Email"
msgstr "E-mail για συγκεντρωτική αναφορά"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:109

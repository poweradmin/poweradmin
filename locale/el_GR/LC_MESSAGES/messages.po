msgstr "Χρήση της ίδιας πολιτικής με τον κύριο τομέα"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:82
msgid "None"
msgstr "Καμία"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:82

msgstr "Settings πολιτικής"

#: lib/Module/DnsWizard/Service/SPFWizard.php:138
msgid "Policy"
msgstr "Πολιτική"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:68
msgid "None (monitor only)"
msgstr "Καμία (μόνο για τον συντονιστή)"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:68
msgid "No action taken, just collect reports for analysis"
msgstr "Δεν έγινε καμία ενέργεια, απλά συλλέγουμε εκθέσεις για ανάλυση"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:83
msgid "Quarantine"
msgstr "Καραντίνα"

#: lib/Module/DnsWizard/Service/DMARCWizard.php:69
